# OpenRouter API Key
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Vercel API Token
# Получить: https://vercel.com/account/tokens
VERCEL_TOKEN=...

# Кастомный домен для субдоменов (опционально)
# Пример: primum-digital.store → studio.primum-digital.store
CUSTOM_DOMAIN=

# Supabase (для БД и хранилища картинок)
# Получить: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Порт сервера (опционально)
PORT=3001

# === Для фронтенда (web/.env) ===
# VITE_SUPABASE_URL=https://xxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
